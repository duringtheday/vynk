# ══════════════════════════════════════════════════════════════
# VYNK — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ══════════════════════════════════════════════════════════════

# Neon Database
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/builder
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/builder

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_NEW_CARD=YOUR_STRIPE_PRICE_ID_20
STRIPE_PRICE_RENEWAL=YOUR_STRIPE_PRICE_ID_10

# App
NEXT_PUBLIC_APP_URL=https://vynk.app
NEXT_PUBLIC_APP_NAME=Vynk

# Owner
OWNER_CLERK_ID=YOUR_CLERK_USER_ID
OWNER_EMAIL=your@email.com
ADMIN_PIN_HASH=YOUR_BCRYPT_HASH
ADMIN_SESSION_MINUTES=15

# Resend
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Security
SESSION_SECRET=YOUR_RANDOM_64_HEX_STRING